# Pure Home — корневой .htaccess
# Front controller + базовая безопасность

Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # RewriteBase автоопределяется Apache по расположению .htaccess —
    # одинаково работает и в корне, и в подпапке /_new/.

    # Защита служебных каталогов
    RewriteRule ^app/      - [F,L]
    RewriteRule ^data/     - [F,L]

    # Запрет доступа к dotfiles (.git, .env, .htaccess)
    RewriteRule (^|/)\.   - [F,L]

    # Существующие файлы и папки отдаём напрямую (public/, uploads/, favicon, robots)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Всё остальное — на front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Безопасные заголовки
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "interest-cohort=()"
</IfModule>

# Сжатие
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml image/svg+xml
</IfModule>

# Кеш для статики
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType image/svg+xml           "access plus 1 month"
    ExpiresByType image/png               "access plus 1 month"
    ExpiresByType image/jpeg              "access plus 1 month"
    ExpiresByType image/webp              "access plus 1 month"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType font/ttf                "access plus 1 year"
</IfModule>

# 404 контролирует front controller внутри маршрутизатора.

# 301-редиректы со старых URL (Nicepage HTML-страниц) на новые.
# Активируются только когда сайт в корне (на /_new/ старых URL и так нет).
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^index\.html$        / [R=301,L]
    RewriteRule ^about\.html$        /about [R=301,L]
    RewriteRule ^services\.html$     /services [R=301,L]
    RewriteRule ^documents\.html$    /documents [R=301,L]
    RewriteRule ^report\.html$       /documents [R=301,L]
    RewriteRule ^news\.html$         /news [R=301,L]
    RewriteRule ^contacts\.html$     /contacts [R=301,L]
    RewriteRule ^feed-back\.html$    /contacts [R=301,L]
</IfModule>
